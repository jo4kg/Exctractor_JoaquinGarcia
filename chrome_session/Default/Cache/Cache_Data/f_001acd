	var updateWorkflowAlerts = function () {
		$.ajax({
			url: Bcri.Core.getDomain() + "Alert/getWorkflowAlerts",

		}).done(function (data) {
			$("#alertPendingReview").text(data.result.pendingReview);
			$("#alertPendingApproval").text(data.result.pendingApproval);
			$("#alertIncorrect").text(data.result.pendingIncorrect);
			$("#alertPendingExecution").text(data.result.pendingExecution);
			$("#alertPendingCounterpartyExecution").text(data.result.pendingCounterpartyExecution);
			$("#alertPendingWires").text(data.result.pendingWires);
			$("#alertPendingSendingSettlement").text(data.result.pendingSettlement);
			if (data.result.error != undefined) {
				console.log("Error trying to get workflowAlerts" + data.result.error);
			}
		});
	};

