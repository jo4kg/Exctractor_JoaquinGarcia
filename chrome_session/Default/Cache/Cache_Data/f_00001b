                calculateCustomSummary: function (options) {
                    switch (options.name) {
                        case 'WAC':
                            {
                                switch (options.summaryProcess) {
                                    case 'start':
                                        {
                                            options.totalValue = 0;
                                            options.totalPrincipal = 0;
                                            break;
                                        }
                                    case 'calculate':
                                        {
                                            var migrilla = options.component;
                                            options.component.getDataByKeys([options.value])
                                                .then(function (data) {
                                                    var rowData = data[0];
                                                    options.totalValue += Math.abs(rowData.PrincipalAmount) * (rowData.CouponFixedRate / 100);
                                                    options.totalPrincipal += Math.abs(rowData.PrincipalAmount);
                                                });
                                            break;
                                        }
                                    case 'finalize':
                                        {
                                            options.totalValue = (options.totalValue / options.totalPrincipal) * 100;
                                            break;
                                        }

                                }
                                break;
                            }
                        case 'WAM':
                            {
                                switch (options.summaryProcess) {
                                    case 'start':
                                        {
                                            options.totalValue = 0;
                                            options.totalWAM = 0;
                                            break;
                                        }
                                    case 'calculate':
                                        {
                                            var migrilla = options.component;
                                            options.component.getDataByKeys([options.value])
                                                .then(function (data) {
                                                    var rowData = data[0];
                                                    options.totalWAM += -Math.abs(rowData.PrincipalAmount) * moment().diff(rowData.MaturityDate, 'days');
                                                    options.totalValue += Math.abs(rowData.PrincipalAmount);
                                                });
                                            break;
                                        }
                                    case 'finalize':
                                        {
                                            options.totalValue = (options.totalWAM / options.totalValue) / 360;
                                            break;
                                        }
                                }
                                break;
                            }
                    }
                }

