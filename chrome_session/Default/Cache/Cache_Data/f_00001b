function loadTree(id) {

    $("#progressBar").hide();
    $("#dashBoard").hide();
    id = parseInt(id);
    if (!id) return;

    $("#progressBar").show();

    $.getJSON(urlBase + '/TradeTree/Data/' + id, function (data) {
        if (data.length > 0) {
            $("#progressBar").hide();
            $("#dashBoard").show();

            renderTree(data[0]);
        } else {
            if (data.Redirect) {
                window.location = data.Redirect;
            } else {
                $("#progressBar").hide();
                $("#dashBoard").hide();

                alert("No data available.");
            }
        }
    }).fail(function (jqXhr, textStatus, errorThrown) {
        $("#progressBar").hide();
        $("#dashBoard").hide();

        console.error(textStatus + " - " + errorThrown);
        //alert("Could not perform the requested operation.");

        swal("Error!", "Trade Tree Data error, if error persist contact System Administrator", "error",
            {
                buttons: {
                    cancel: "Exit",
                },
            });
        $(".swal-text").css("text-align", "center");

        Bcri.Core.LoadingScreen.hide();
        return;
    });
}
function renderTree(data) {
    removeNulls(data);
    return d3.treeLayout(data);
}
function renderTreeFile(data) {
    removeNulls(data);
    return d3.treeLayoutFile(data);
}

function findNode(id, currentNode) {
    var i,
        currentChild,
        result;

    if (id === currentNode.id) {
        return currentNode;
    } else {

        // Use a for loop instead of forEach to avoid nested functions
        // Otherwise "return" will not work properly
        for (i = 0; i < currentNode.children.length; i += 1) {
            currentChild = currentNode.children[i];

            // Search in the current child
            result = findNode(id, currentChild);

            // Return the result if the node has been found
            if (result !== false) {
                return result;
            }
        }

        // The node has not been found and we have no more options
        return false;
    }
}
function removeNulls(obj) {
    // Compact arrays with null entries; delete keys from objects with null value
    var isArray = obj instanceof Array;
    for (var k in obj) {
        if (obj.hasOwnProperty(k)) {
            if (obj[k] === "") isArray ? obj.splice(k, 1) : delete obj[k];
            else if (typeof obj[k] == "object") removeNulls(obj[k]);
        }
    }
}
