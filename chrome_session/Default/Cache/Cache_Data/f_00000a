function urlQueryFromObject(requestParams) {
    var _urlParams = '?';
    Object.keys(requestParams).forEach((key) => {
        if (requestParams[key]) {
            if (Array.isArray(requestParams[key])) {
                requestParams[key].forEach((item) => {
                    _urlParams += key + '=' + item + "&";
                });
            } else {
                _urlParams += key + '=' + requestParams[key] + "&";
            }
        }
    });
    return _urlParams.slice(0, -1);
}
