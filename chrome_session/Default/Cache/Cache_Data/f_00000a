 */
var getPartialFromAjax = function (specificUrl, reqData, responseFunction, _cache, showLoading, async) {
	executeAjax(specificUrl, reqData, responseFunction, _cache, "text", "POST", showLoading, async);
};

/**
 * @param {string} _reportCode = ex: "WorkFlowVehicleEntity"
 * @param {PlainObject} reqData = ex: {flowId : 2}
 * @param {Function} responseFunction= ex: use: processResponse, def:var processResponse = function(data)
 * @param {bool} _cache= ex: false
 * @param {bool} showLoading = ex: false; if showLoading is true, is async forced... not matters what do you pass at async
 * @param {bool} async= ex: false
 */
var getReportFromAjax = function (_reportCode, reqData, responseFunction, _cache, showLoading, async) {
	if (!reqData) {
		reqData = {};
	}
	reqData.ReportCode = _reportCode;
	getDataFromAjax("Report/Data", reqData, responseFunction, _cache, showLoading, async);
};

/**
 * @param {string} specificUrl = ex: "/WorkFlowCashEventEntity/getFlowStatus"
 * @param {PlainObject} reqData = ex: {flowId : 2}
 * @param {Function} responseFunction = ex: use: processResponse, def:var processResponse = function(data)
 * @param {bool} showLoading = ex: false; if showLoading is true, is async forced... not matters what do you pass at async
 * @param {bool} async = ex: false
 */
var postDataToAjax = function (specificUrl, reqData, responseFunction, showLoading, async) {
	executeAjax(specificUrl, reqData, responseFunction, false, "json", "POST", showLoading, async);
};

var executeAjax = function (specificUrl, reqData, responseFunction, _cache, dataType, ajaxType, showLoading = false, async = false) {


	if (!_ajaxCount && showLoading) {
		$("#block-wrapper").show({ duration: 0, done: callAjaxEvent(specificUrl, reqData, responseFunction, _cache, dataType, ajaxType, showLoading, async) });
	} else {
		callAjaxEvent(specificUrl, reqData, responseFunction, _cache, dataType, ajaxType, showLoading, async);
	}
};

var callAjaxEvent = function (specificUrl, reqData, responseFunction, _cache, dataType, ajaxType, showLoading, async) {
	if (showLoading) {
		_ajaxCount++;
	}
	var _url = baseUrl + specificUrl;
	$.ajax({
		url: _url,
		//global: false,
		type: ajaxType,
		data: reqData,
		dataType: dataType,
		async: showLoading ? showLoading : async,
		cache: _cache,
		complete: function (data) {
			if (showLoading) {
				_ajaxCount--;
				if (!_ajaxCount) {
					Bcri.Core.LoadingScreen.hide();
				}
			}
		},
		success: function (data) {
			responseFunction(data);
		},
		error: function (xhr, ajaxOptions, thrownError) {
			var errorMessage = (xhr && xhr.responseText) ? xhr.responseText : "An error has occurred. Please try again. In case the error persists, contact the System Administrator.";

			if (showLoading) {
				swal("Error", errorMessage, "error");
			} else {
				console.log(errorMessage);
			}
		}
	});
};
