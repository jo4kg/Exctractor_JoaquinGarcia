/**
 * @param {any} idDatepicker = ex: asofdate when #asofdate is the selector, the checkBox must have the class checkBoxFor-{idDatepicker} ex: checkBoxFor-asofdate
 * @param {any} defaultDate = ex new Date()
 */
var InitializeDatePicker = function (idDatepicker, defaultDate = null) {
    if (!defaultDate) {
        defaultDate = new Date();
    }
    $("#" + idDatepicker).datepicker().datepicker("setDate", defaultDate);
    var check = $(".checkBoxFor-" + idDatepicker);
    check.change(function (event) {
        ControlDatePicker(event.target, idDatepicker, defaultDate);
    });
    $("#" + idDatepicker).change((event) => {
        if ($(".checkBoxFor-" + idDatepicker).prop("checked") && !$("#" + idDatepicker).val()) {
            $("#" + idDatepicker).datepicker("setDate", defaultDate);
        }
    });
};

var DisableDatePicker = function (idDatepicker) {
    var check = $(".checkBoxFor-" + idDatepicker).prop("checked", false);
    ControlDatePicker(check, idDatepicker);
};

var ControlDatePicker = function (check, idDatepicker, defaultDate = null) {
    if (!defaultDate) {
        defaultDate = new Date();
    }
    var dp = $("#" + idDatepicker).datepicker();
    var enabled = !$(check).prop("checked");
    enabled ? dp.datepicker("setDate", '') : dp.datepicker("setDate", defaultDate);
    $('#' + idDatepicker).prop('disabled', enabled);
    $('#' + idDatepicker).change();
};

