var loadFlags = function (guid) {

	if (!guid) {
		guid = newguid();
	}
	if ($("#flags-cashEvent").length) {
		//getReportFromAjax(_reportCode, reqData, responseFunction, _cache, showLoading, async)
		getReportFromAjax('WorkFlowCashEventFlags', { 'guid': guid }, FillCashEventFlags, true, false, true);
	}
	if ($("#flags-VehicleEntity").length) {
		//getReportFromAjax(_reportCode, reqData, responseFunction, _cache, showLoading, async)
		getReportFromAjax('WorkFlowVehicleEntityFlags', { 'guid': guid }, FillVehicleEntityFlags, true, false, true);
	}
};

var FillCashEventFlags = function (data) {
	if (data && data.length) {
		$("#flags-cashEvent").html("");
		for (var i = 0; i < data.length; i++) {
			if (
				(data[i].Code.includes('Review') && permissionReviewCashEvent) ||
				(data[i].Code.includes('Approval') && permissionApprovalCashEvent) ||
				(data[i].Code.includes('CalculateOk')) ||
				(data[i].Code.includes('CalculatePending') && permissionCalculateCashEvent)
			) {
				addFlag(data[i], 'flags-cashEvent');
			}
		}
	}
};


var FillVehicleEntityFlags = function (data) {
	if (data && data.length) {
		$("#flags-VehicleEntity").html("");
		for (var i = 0; i < data.length; i++) {
			addFlag(data[i], 'flags-VehicleEntity');
		}
	}
};

var addFlag = function (data, flagList) {
	var url = getUrl(data);
	var flag = flagTemplate.replace("{Color}", data.Color).replace("{Title}", data.Name).replace("{AlertCount}", data.Count).replace("{URL}", url);
	$("#" + flagList).append(flag);
};

var getUrl = function (data) {
	if (!data.Code.includes('CalculatePending')) {
		return flagWorkFlowCashVehicleUrl.replace("{IdStatusConfig}", data.statusConfig_Id).replace("{Status_Id}", data.Status_Id);
	} else {
		return flagCalculateUrl;
	}
}

